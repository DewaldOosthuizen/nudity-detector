# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec
# Un-ignore the tracked PyInstaller spec kept in scripts/
!scripts/*.spec

# Build tools downloaded by scripts/build_linux.sh (not committed)
scripts/appimagetool*.AppImage
scripts/linuxdeploy*.AppImage
scripts/linuxdeploy-plugin-gtk.sh

# Installer logs
